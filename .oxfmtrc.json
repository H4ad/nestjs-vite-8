{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 80,
  "sortPackageJson": true,
  "bracketSpacing": true,
  "sortImports": {
    "order": "asc",
    "newlinesBetween": false,
    "sortSideEffects": false
  },
  "ignorePatterns": ["node_modules"]
}
